APP_NAME=EvidenceChain
APP_ENV=development
APP_DEBUG=false
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///./storage/evidencechain.db
TRUSTED_SOURCE_DOMAINS=nih.gov,cdc.gov,who.int,edu,gov
TRANSCRIPT_CHUNK_MAX_CHARS=1200
TRANSCRIPT_CHUNK_OVERLAP_SEGMENTS=1
TRANSCRIPT_RETRY_ATTEMPTS=3
TRANSCRIPT_RETRY_BACKOFF_SECONDS=0.5
TRANSCRIPT_FETCH_TIMEOUT_SECONDS=20
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_MODEL=claude-3-5-haiku-latest
OLLAMA_MODEL=llama3.1
