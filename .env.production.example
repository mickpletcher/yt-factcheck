APP_NAME=EvidenceChain
APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:////data/evidencechain.db
API_ACCESS_TOKEN=change-this-before-public-use
API_RATE_LIMIT_PER_MINUTE=60
TRUSTED_SOURCE_DOMAINS=nih.gov,cdc.gov,who.int,edu,gov,nature.com,science.org,reuters.com,apnews.com,bbc.com
TRANSCRIPT_CHUNK_MAX_CHARS=1200
TRANSCRIPT_CHUNK_OVERLAP_SEGMENTS=1
TRANSCRIPT_RETRY_ATTEMPTS=3
TRANSCRIPT_RETRY_BACKOFF_SECONDS=0.5
TRANSCRIPT_FETCH_TIMEOUT_SECONDS=20
LLM_PROVIDER=openai
LLM_FAILOVER_PROVIDERS=anthropic
LLM_REQUEST_TIMEOUT_SECONDS=60
LLM_HEALTH_TIMEOUT_SECONDS=10
LLM_COST_RATES=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_MAX_TOKENS=4096
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
LMSTUDIO_BASE_URL=http://lmstudio:1234/v1
LMSTUDIO_MODEL=local-model
SEARCH_PROVIDER=brave
SEARCH_FAILOVER_PROVIDERS=tavily
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_ENDPOINT=https://api.search.brave.com/res/v1/web/search
TAVILY_API_KEY=
TAVILY_SEARCH_ENDPOINT=https://api.tavily.com/search
BING_SEARCH_API_KEY=
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search
SERPAPI_API_KEY=
EVIDENCE_SEARCH_TIMEOUT_SECONDS=15
EVIDENCE_SEARCH_RETRY_ATTEMPTS=3
EVIDENCE_SEARCH_RETRY_BACKOFF_SECONDS=0.5
EVIDENCE_SEARCH_RATE_LIMIT_PER_SECOND=1
EVIDENCE_SEARCH_CACHE_TTL_SECONDS=3600
EVIDENCE_SEARCH_MAX_QUERIES=4
EVIDENCE_SEARCH_RESULTS_PER_QUERY=5
PIPELINE_WORKER_COUNT=1
PIPELINE_RETRY_ATTEMPTS=3
PIPELINE_RETRY_BACKOFF_SECONDS=1
REPORT_EXPORT_DIR=reports
REPORT_EXPORT_RETENTION_DAYS=30
WEB_CONCURRENCY=2
WEB_TIMEOUT=120
